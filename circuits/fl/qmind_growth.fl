// ── Record Growth Evidence ──────────────────────────────────────

circuit record_growth_evidence(
    user_id: bytes(16),
    action_id: bytes(16),
    evidence_type: u8,
    description: string,
    resonance_id: option<bytes(32)>,
    signing_sk: bytes(4896),
) -> GrowthEvidenceRecord
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision C
    povc true
    observe metrics: [evidence_recorded, evidence_by_type]
    meters [compute_cycles, memory_bytes]
    wasm_abi [now, mldsa_sign]
    test golden "record_self_report" {
        let sk = bytes(4896, 0xBB)
        let result = record_growth_evidence(
            bytes(16, 0x01), bytes(16, 0x02), 0,
            "Practiced accepting imperfection today", Option::None, sk)
        assert result.evidence_type == 0
        assert result.significance_bps > 0
    }
{
    let ts = now_ns() / 1000000
    let evidence_id = bit_slice(sha3_256(concat(user_id, action_id, ts)), 0, 128)

    let significance = match evidence_type {
        0 => 5000,
        1 => 7000,
        2 => 8000,
        3 => 6000,
        4 => 7500,
        _ => 3000,
    }

    let record = GrowthEvidenceRecord {
        evidence_id: evidence_id,
        action_id: action_id,
        user_id: user_id,
        evidence_type: evidence_type,
        description_hash: sha3_256(description),
        resonance_id: match resonance_id {
            Option::Some(r) => r,
            Option::None => bytes(32, 0x00),
        },
        insight_id: bytes(16, 0x00),
        significance_bps: significance,
        captured_at: ts,
    }

    let _sig = mldsa_sign(signing_sk, serialize(record))
    eslm_feed(personal_growth, serialize(record), significance)

    qkit_metering::record_usage(user_id, "mind_growth_evidence", DimensionValues {
        executions: 1, hashes: 1, bandwidth: 0,
        storage: 128, observables: 1, proofs: 0, circuits: 1, mpc_sessions: 0,
    })

    record
}

// ── Link Resonance to Growth ────────────────────────────────────

circuit link_resonance_to_growth(
    user_id: bytes(16),
    resonance_id: bytes(32),
    topic_sentiments: list<string>,
    active_actions: list<GrowthActionRecord>,
    enneagram_profile: EnneagramProfileRecord,
) -> list<ResonanceGrowthLink>
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision C
    povc true
    observe metrics: [resonance_growth_links, auto_links, integration_links]
    meters [compute_cycles, memory_bytes]
    wasm_abi [eslm_similarity]
{
    let links = []
    let integration_keywords = integration_keywords_for_type(enneagram_profile.core_type)

    for action in active_actions {
        for topic in topic_sentiments {
            let relevance = eslm_similarity(topic, action.description_hash)
            if relevance > 4000 {
                let direction = if action.domain == 0 { 0 }
                    else if action.domain == 1 { 1 }
                    else { 2 }

                links.push(ResonanceGrowthLink {
                    resonance_id: resonance_id,
                    action_id: action.action_id,
                    relevance_bps: relevance,
                    growth_direction: direction,
                    auto_detected: true,
                })
            }
        }
    }

    qkit_metering::record_usage(user_id, "mind_growth_link_resonance", DimensionValues {
        executions: 1, hashes: len(links), bandwidth: 0,
        storage: 0, observables: 1, proofs: 0, circuits: 1, mpc_sessions: 0,
    })

    links
}

circuit integration_keywords_for_type(core_type: u8) -> list<string>
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision A
    povc true
{
    match core_type {
        1 => ["spontaneity", "joy", "play", "freedom", "adventure", "relaxation"],
        2 => ["self-awareness", "creativity", "boundaries", "identity", "solitude"],
        3 => ["loyalty", "authenticity", "team", "trust", "vulnerability", "process"],
        4 => ["discipline", "objectivity", "consistency", "structure", "action"],
        5 => ["confidence", "engagement", "action", "leadership", "physicality"],
        6 => ["peace", "trust", "stillness", "acceptance", "serenity"],
        7 => ["depth", "focus", "wisdom", "contemplation", "patience", "solitude"],
        8 => ["vulnerability", "tenderness", "nurture", "empathy", "service"],
        9 => ["assertion", "ambition", "goals", "initiative", "self-expression"],
        _ => [],
    }
}

// ── Compute Growth Snapshot ─────────────────────────────────────

circuit compute_growth_snapshot(
    user_id: bytes(16),
    actions: list<GrowthActionRecord>,
    enneagram: EnneagramProfileRecord,
) -> GrowthSnapshotRecord
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision C
    povc true
    observe metrics: [snapshots_computed, integration_progress_avg]
    meters [compute_cycles, memory_bytes]
    wasm_abi [now]
{
    let ts = now_ns() / 1000000
    let snapshot_id = bit_slice(sha3_256(concat(user_id, ts)), 0, 128)

    let active = 0
    let completed = 0
    let integration_evidence = 0
    let total_integration_actions = 0
    let stress_signals = 0

    for action in actions {
        if action.status == 1 or action.status == 2 { active = active + 1 }
        if action.status == 3 { completed = completed + 1 }
        if action.domain == 0 {
            total_integration_actions = total_integration_actions + 1
            integration_evidence = integration_evidence + action.progress_bps
        }
    }

    let integration_progress = if total_integration_actions > 0 {
        integration_evidence / total_integration_actions
    } else { 0 }

    GrowthSnapshotRecord {
        snapshot_id: snapshot_id,
        user_id: user_id,
        snapshot_at: ts,
        health_level: enneagram.health_level,
        active_actions: active,
        completed_actions: completed,
        integration_progress_bps: integration_progress,
        stress_indicator_bps: stress_signals,
        domain_summary_hash: sha3_256(concat(user_id, integration_progress, ts)),
    }
}

// ── Detect Stress Pattern ───────────────────────────────────────

circuit detect_stress_pattern(
    user_id: bytes(16),
    recent_snapshots: list<GrowthSnapshotRecord>,
    enneagram: EnneagramProfileRecord,
) -> u16
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision C
    povc true
    observe metrics: [stress_detections, stress_level_avg]
    meters [compute_cycles]
{
    if len(recent_snapshots) < 2 { return 0 }

    let latest = recent_snapshots[len(recent_snapshots) - 1]
    let previous = recent_snapshots[len(recent_snapshots) - 2]

    let integration_declining = latest.integration_progress_bps < previous.integration_progress_bps
    let evidence_stalling = latest.active_actions > 0 and latest.completed_actions == previous.completed_actions

    let stress = 0
    if integration_declining { stress = stress + 3000 }
    if evidence_stalling { stress = stress + 2000 }
    if latest.health_level > previous.health_level { stress = stress + 2500 }
    if stress > 10000 { stress = 10000 }

    stress
}

// ── Growth Dashboard ────────────────────────────────────────────

circuit get_growth_dashboard(
    user_id: bytes(16),
    enneagram: EnneagramProfileRecord,
    actions: list<GrowthActionRecord>,
    recent_links: u32,
) -> GrowthDashboard
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision B
    povc true
    observe metrics: [dashboard_views]
{
    let active = 0
    let completed = 0
    let total_evidence = 0

    for action in actions {
        if action.status == 1 or action.status == 2 { active = active + 1 }
        if action.status == 3 { completed = completed + 1 }
        total_evidence = total_evidence + action.evidence_count
    }

    let snapshot = compute_growth_snapshot(user_id, actions, enneagram)

    GrowthDashboard {
        core_type: enneagram.core_type,
