// Q Mind Personal Growth — Enneagram-centered growth tracking (v0.2.0)
//
// Lex Architecture:
//   esn/global/org/polyqlabs/mind/growth
//   Personality profiles, growth actions, evidence, trajectory snapshots
//   Resonance-growth linking for content-driven development
//
// Spec: specs/POLYMIND_PERSONAL_GROWTH_SPEC.md

import qkit_identity
import qkit_metering

// ── Enneagram Types ─────────────────────────────────────────────

type EnneagramType = enum {
    Reformer,     // 1
    Helper,       // 2
    Achiever,     // 3
    Individualist, // 4
    Investigator, // 5
    Loyalist,     // 6
    Enthusiast,   // 7
    Challenger,   // 8
    Peacemaker,   // 9
}

type InstinctualVariant = enum {
    SelfPreservation,
    Sexual,
    Social,
}

type GrowthDomain = enum {
    IntegrationDirection,
    WingDevelopment,
    InstinctualBalance,
    HealthLevel,
    EmotionalIntelligence,
    RelationalCapacity,
    SelfAwareness,
    StressManagement,
    PurposeClarity,
    CliftonStrengthsDev,
    WorkingGeniusGrowth,
    Custom,
}

type AssessmentSource = enum {
    Professional,
    SelfAssessedGuided,
    SelfAssessedDeclared,
    BehavioralInference,
}

type EvidenceType = enum {
    SelfReport,
    Behavioral,
    Resonance,
    Insight,
    Feedback,
}

type GrowthActionStatus = enum {
    Suggested,
    Accepted,
    InProgress,
    Completed,
    Declined,
}

// ── Data: Stored growth entities ────────────────────────────────

data EnneagramProfileRecord : mind/growth v1 {
    user_id: bytes(16),
    core_type: u8,
    wing: u8,
    integration_type: u8,
    disintegration_type: u8,
    tritype_head: u8,
    tritype_heart: u8,
    tritype_gut: u8,
    instinctual_primary: u8,
    instinctual_secondary: u8,
    instinctual_tertiary: u8,
    health_level: u8,
    assessment_source: u8,
    confidence_bps: u16,
    assessed_at: u64,
    updated_at: u64,
}
    store kv
    govern lex esn/global/org/polyqlabs/mind/growth
    cortex {
        infer on_write
        on_anomaly alert "mind-team"
    }

data ComplementaryProfileRecord : mind/growth v1 {
    user_id: bytes(16),
    mbti_type: string,
    mbti_cognitive_stack: string,
    clifton_top_5: string,
    clifton_executing_bps: u16,
    clifton_influencing_bps: u16,
    clifton_relationship_bps: u16,
    clifton_strategic_bps: u16,
    disc_d_bps: u16,
    disc_i_bps: u16,
    disc_s_bps: u16,
    disc_c_bps: u16,
    disc_natural: string,
    disc_adapted: string,
    wg_genius_1: string,
    wg_genius_2: string,
    wg_competency_1: string,
    wg_competency_2: string,
    wg_frustration_1: string,
    wg_frustration_2: string,
    belbin_preferred: string,
    kolbe_ff: u8,
    kolbe_ft: u8,
    kolbe_qs: u8,
    kolbe_im: u8,
    updated_at: u64,
}
    store kv
    govern lex esn/global/org/polyqlabs/mind/growth

data GrowthActionRecord : mind/growth v1 {
    action_id: bytes(16),
    user_id: bytes(16),
    domain: u8,
    description_hash: bytes(32),
    source_framework: string,
    priority_bps: u16,
    status: u8,
    evidence_count: u32,
    created_at: u64,
    last_evidence_at: u64,
    progress_bps: u16,
}
    store kv
    govern lex esn/global/org/polyqlabs/mind/growth
    cortex {
        infer on_write
        on_suggestion store "cortex/mind/growth_feedback"
    }

data GrowthEvidenceRecord : mind/growth v1 {
    evidence_id: bytes(16),
    action_id: bytes(16),
    user_id: bytes(16),
    evidence_type: u8,
    description_hash: bytes(32),
    resonance_id: bytes(32),
    insight_id: bytes(16),
    significance_bps: u16,
    captured_at: u64,
}
    store kv
    govern lex esn/global/org/polyqlabs/mind/growth

data GrowthSnapshotRecord : mind/growth v1 {
    snapshot_id: bytes(16),
    user_id: bytes(16),
    snapshot_at: u64,
    health_level: u8,
    active_actions: u32,
    completed_actions: u32,
    integration_progress_bps: u16,
    stress_indicator_bps: u16,
    domain_summary_hash: bytes(32),
}
    store kv
    govern lex esn/global/org/polyqlabs/mind/growth

// ── Internal Types ──────────────────────────────────────────────

type GrowthActionTemplate = struct {
    domain: u8,
    description: string,
    source_framework: string,
    priority_bps: u16,
}

type ResonanceGrowthLink = struct {
    resonance_id: bytes(32),
    action_id: bytes(16),
    relevance_bps: u16,
    growth_direction: u8,
    auto_detected: bool,
}

type GrowthDashboard = struct {
    core_type: u8,
    health_level: u8,
    integration_type: u8,
    integration_progress_bps: u16,
    stress_indicator_bps: u16,
    active_actions: u32,
    completed_actions: u32,
    total_evidence: u32,
    top_growth_domains: list<DomainProgress>,
    recent_resonance_links: u32,
}

type DomainProgress = struct {
    domain: u8,
    progress_bps: u16,
    trend: u8,
    evidence_count: u32,
}

// ── Integration line lookup ─────────────────────────────────────

circuit integration_type_for(core_type: u8) -> u8
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision A
    povc true
    test golden "type_1_integrates_to_7" { assert integration_type_for(1) == 7 }
    test golden "type_7_integrates_to_5" { assert integration_type_for(7) == 5 }
    test golden "type_9_integrates_to_3" { assert integration_type_for(9) == 3 }
{
    match core_type {
        1 => 7,
        2 => 4,
        3 => 6,
        4 => 1,
        5 => 8,
        6 => 9,
        7 => 5,
        8 => 2,
        9 => 3,
        _ => 0,
    }
}

circuit disintegration_type_for(core_type: u8) -> u8
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision A
    povc true
    test golden "type_1_disintegrates_to_4" { assert disintegration_type_for(1) == 4 }
    test golden "type_7_disintegrates_to_1" { assert disintegration_type_for(7) == 1 }
{
    match core_type {
        1 => 4,
        2 => 8,
        3 => 9,
        4 => 2,
        5 => 7,
        6 => 3,
        7 => 1,
        8 => 5,
        9 => 6,
        _ => 0,
    }
}

// ── Set Enneagram Profile ───────────────────────────────────────

circuit set_enneagram_profile(
    user_id: bytes(16),
    core_type: u8,
    wing: u8,
    tritype: list<u8>,
    instinctual_stack: list<u8>,
    health_level: u8,
    assessment_source: u8,
    signing_sk: bytes(4896),
) -> EnneagramProfileRecord
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision C
    povc true
    observe metrics: [profiles_set, profile_updates]
    meters [compute_cycles, memory_bytes]
    wasm_abi [now, mldsa_sign]
    test golden "set_valid_profile" {
        let sk = bytes(4896, 0xBB)
        let result = set_enneagram_profile(bytes(16, 0x01), 7, 6, [7, 2, 9], [1, 0, 2], 5, 2, sk)
        assert result.core_type == 7
        assert result.wing == 6
        assert result.integration_type == 5
        assert result.disintegration_type == 1
    }
{
    let ts = now_ns() / 1000000
    let integration = integration_type_for(core_type)
    let disintegration = disintegration_type_for(core_type)

    let confidence = match assessment_source {
        0 => 10000,
        1 => 7000,
        2 => 5000,
        3 => 3000,
        _ => 2000,
    }

    let record = EnneagramProfileRecord {
        user_id: user_id,
        core_type: core_type,
        wing: wing,
        integration_type: integration,
        disintegration_type: disintegration,
        tritype_head: if len(tritype) > 0 { tritype[0] } else { 0 },
        tritype_heart: if len(tritype) > 1 { tritype[1] } else { 0 },
        tritype_gut: if len(tritype) > 2 { tritype[2] } else { 0 },
        instinctual_primary: if len(instinctual_stack) > 0 { instinctual_stack[0] } else { 0 },
        instinctual_secondary: if len(instinctual_stack) > 1 { instinctual_stack[1] } else { 0 },
        instinctual_tertiary: if len(instinctual_stack) > 2 { instinctual_stack[2] } else { 0 },
        health_level: health_level,
        assessment_source: assessment_source,
        confidence_bps: confidence,
        assessed_at: ts,
        updated_at: ts,
    }

    let _sig = mldsa_sign(signing_sk, serialize(record))
    eslm_feed(personal_growth, serialize(record), confidence)

    qkit_metering::record_usage(user_id, "mind_growth_profile", DimensionValues {
        executions: 1, hashes: 1, bandwidth: 0,
        storage: 256, observables: 1, proofs: 0, circuits: 1, mpc_sessions: 0,
    })

    record
}

// ── Generate Growth Actions ─────────────────────────────────────

circuit generate_growth_actions(
    user_id: bytes(16),
    profile: EnneagramProfileRecord,
) -> list<GrowthActionRecord>
    profile poly_framework_standard
    lex esn/global/org/polyqlabs/mind/growth
    precision C
    povc true
    observe metrics: [growth_actions_generated]
    meters [compute_cycles, memory_bytes]
    wasm_abi [now]
    test golden "type_7_generates_depth_actions" {
        let profile = EnneagramProfileRecord {
            user_id: bytes(16, 0x01), core_type: 7, wing: 6,
            integration_type: 5, disintegration_type: 1,
            tritype_head: 7, tritype_heart: 2, tritype_gut: 9,
            instinctual_primary: 1, instinctual_secondary: 0, instinctual_tertiary: 2,
            health_level: 5, assessment_source: 2, confidence_bps: 5000,
            assessed_at: 1000, updated_at: 1000,
        }
        let actions = generate_growth_actions(bytes(16, 0x01), profile)
        assert len(actions) >= 3
    }
{
    let ts = now_ns() / 1000000
    let templates = growth_templates_for_type(profile.core_type)
    let actions = []

    for i in 0..len(templates) {
        let template = templates[i]
        let action_id = bit_slice(sha3_256(concat(user_id, template.description, ts, i)), 0, 128)
        let action = GrowthActionRecord {
            action_id: action_id,
            user_id: user_id,
            domain: template.domain,
            description_hash: sha3_256(template.description),
            source_framework: template.source_framework,
            priority_bps: template.priority_bps,
            status: 0,
            evidence_count: 0,
            created_at: ts,
            last_evidence_at: 0,
            progress_bps: 0,
        }
        actions.push(action)
    }

    qkit_metering::record_usage(user_id, "mind_growth_generate", DimensionValues {
        executions: 1, hashes: len(actions), bandwidth: 0,
        storage: len(actions) * 128, observables: 1, proofs: 0, circuits: 1, mpc_sessions: 0,
    })

    actions
}

