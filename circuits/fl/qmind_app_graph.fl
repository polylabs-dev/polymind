// ═══════════════════════════════════════════════════════════════════════════════
// §2  Graph Registration (14 modules)
// ═══════════════════════════════════════════════════════════════════════════════

circuit qmind_app_graph_register(graph: CsrStorage) -> CsrStorage
    lex polyqlabs/qmind
    @status production
    @precision B
    @attested true
    invariant "capacity" { graph.num_nodes + POLYMIND_MODULE_COUNT as u32 <= 4096 }
    observe metrics: [qmind_module_count, qmind_edge_count, register_latency_ns]
    meters [compute_cycles, memory_bytes]
{
    let (g, id_ingest)       = module_graph_add_module(graph, qmind_ingest_module())
    let (g, id_doc_ingest)   = module_graph_add_module(g, qmind_document_ingest_module())
    let (g, id_classify)     = module_graph_add_module(g, qmind_classify_module())
    let (g, id_eslm)         = module_graph_add_module(g, qmind_eslm_module())
    let (g, id_query)        = module_graph_add_module(g, qmind_query_module())
    let (g, id_insight)      = module_graph_add_module(g, qmind_insight_module())
    let (g, id_rbac)         = module_graph_add_module(g, qmind_rbac_module())
    let (g, id_metering)     = module_graph_add_module(g, qmind_metering_module())
    let (g, id_health)       = module_graph_add_module(g, qmind_platform_health_module())
    let (g, id_guardian)     = module_graph_add_module(g, qmind_guardian_module())
    let (g, id_legacy)       = module_graph_add_module(g, qmind_legacy_module())
    let (g, id_kg)           = module_graph_add_module(g, knowledge_graph_module())
    let (g, id_dag)          = module_graph_add_module(g, legacy_dag_module())
    let (g, id_growth)       = module_graph_add_module(g, qmind_growth_module())

    let ver = POLYMIND_VERSION_STR
    let vc = ">=" ++ POLYMIND_VERSION_STR

    // qmind_ingest -> qmind_classify, knowledge_graph
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_ingest", source_version: ver,
        target_module: "qmind_classify", target_version_constraint: vc, metadata: bytes(0),
    }, id_ingest, id_classify)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_ingest", source_version: ver,
        target_module: "knowledge_graph", target_version_constraint: vc, metadata: bytes(0),
    }, id_ingest, id_kg)

    // qmind_document_ingest -> qmind_ingest, qmind_classify
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_document_ingest", source_version: ver,
        target_module: "qmind_ingest", target_version_constraint: vc, metadata: bytes(0),
    }, id_doc_ingest, id_ingest)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_document_ingest", source_version: ver,
        target_module: "qmind_classify", target_version_constraint: vc, metadata: bytes(0),
    }, id_doc_ingest, id_classify)

    // qmind_eslm -> qmind_classify, knowledge_graph
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_eslm", source_version: ver,
        target_module: "qmind_classify", target_version_constraint: vc, metadata: bytes(0),
    }, id_eslm, id_classify)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_eslm", source_version: ver,
        target_module: "knowledge_graph", target_version_constraint: vc, metadata: bytes(0),
    }, id_eslm, id_kg)

    // qmind_query -> qmind_classify, qmind_eslm, knowledge_graph
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_query", source_version: ver,
        target_module: "qmind_classify", target_version_constraint: vc, metadata: bytes(0),
    }, id_query, id_classify)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_query", source_version: ver,
        target_module: "qmind_eslm", target_version_constraint: vc, metadata: bytes(0),
    }, id_query, id_eslm)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_query", source_version: ver,
        target_module: "knowledge_graph", target_version_constraint: vc, metadata: bytes(0),
    }, id_query, id_kg)

    // qmind_insight -> knowledge_graph, qmind_classify
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_insight", source_version: ver,
        target_module: "knowledge_graph", target_version_constraint: vc, metadata: bytes(0),
    }, id_insight, id_kg)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_insight", source_version: ver,
        target_module: "qmind_classify", target_version_constraint: vc, metadata: bytes(0),
    }, id_insight, id_classify)

    // qmind_guardian -> qmind_rbac, qmind_legacy
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_guardian", source_version: ver,
        target_module: "qmind_rbac", target_version_constraint: vc, metadata: bytes(0),
    }, id_guardian, id_rbac)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_guardian", source_version: ver,
        target_module: "qmind_legacy", target_version_constraint: vc, metadata: bytes(0),
    }, id_guardian, id_legacy)

    // qmind_legacy -> legacy_dag, qmind_rbac, knowledge_graph
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_legacy", source_version: ver,
        target_module: "legacy_dag", target_version_constraint: vc, metadata: bytes(0),
    }, id_legacy, id_dag)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_legacy", source_version: ver,
        target_module: "qmind_rbac", target_version_constraint: vc, metadata: bytes(0),
    }, id_legacy, id_rbac)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_legacy", source_version: ver,
        target_module: "knowledge_graph", target_version_constraint: vc, metadata: bytes(0),
    }, id_legacy, id_kg)

    // qmind_metering -> qmind_rbac
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_metering", source_version: ver,
        target_module: "qmind_rbac", target_version_constraint: vc, metadata: bytes(0),
    }, id_metering, id_rbac)

    // qmind_platform_health -> qmind_metering, qmind_rbac
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_platform_health", source_version: ver,
        target_module: "qmind_metering", target_version_constraint: vc, metadata: bytes(0),
    }, id_health, id_metering)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_platform_health", source_version: ver,
        target_module: "qmind_rbac", target_version_constraint: vc, metadata: bytes(0),
    }, id_health, id_rbac)

    // qmind_growth -> knowledge_graph, qmind_insight, qmind_classify
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_growth", source_version: ver,
        target_module: "knowledge_graph", target_version_constraint: vc, metadata: bytes(0),
    }, id_growth, id_kg)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_growth", source_version: ver,
        target_module: "qmind_insight", target_version_constraint: vc, metadata: bytes(0),
    }, id_growth, id_insight)
    let g = module_graph_add_edge(g, ModuleEdge {
        edge_type: EDGE_REQUIRES, source_module: "qmind_growth", source_version: ver,
        target_module: "qmind_classify", target_version_constraint: vc, metadata: bytes(0),
    }, id_growth, id_classify)

    g
}

// ═══════════════════════════════════════════════════════════════════════════════
// §3  Cross-Graph Bridge Edges
// ═══════════════════════════════════════════════════════════════════════════════

data PolymindBridgeEdgeData : polyqlabs/qmind/bridge v1 {
    source_lex: string,
    source_module: string,
    target_lex: string,
    target_module: string,
    bridge_type: string,
    timestamp_ms: u64,
}

circuit qmind_register_bridge_edges(graph: CsrStorage) -> CsrStorage
    lex polyqlabs/qmind
    @status production
    @precision B
    @attested true
    observe metrics: [bridge_edge_count]
    meters [compute_cycles]
{
    let id_classify = find_qmind_module_id(graph, "qmind_classify")
    let id_doc_ingest = find_qmind_module_id(graph, "qmind_document_ingest")

    let g = graph

    // BRIDGE_TO: qmind_classify -> QKit eslm_classify
    if id_classify != 0xFFFFFFFF as u32 {
        let bridge_qkit = serialize(PolymindBridgeEdgeData {
            source_lex: POLYMIND_APP_LEX, source_module: "qmind_classify",
            target_lex: "polyqlabs/qkit", target_module: "qkit_eslm_classify",
            bridge_type: "eslm_classification", timestamp_ms: 0,
        }) as bytes
        let (g2, bid1) = graph_add_node(g, 0xB0, bridge_qkit)
        g = graph_add_edge(g2, id_classify, bid1, EDGE_BRIDGE_TO, bridge_qkit)
    }

    // BRIDGE_TO: qmind_growth -> eStream Resonance
    let id_growth = find_qmind_module_id(g, "qmind_growth")
    if id_growth != 0xFFFFFFFF as u32 {
        let bridge_resonance = serialize(PolymindBridgeEdgeData {
            source_lex: POLYMIND_APP_LEX, source_module: "qmind_growth",
            target_lex: "esn/global/intelligence/ai", target_module: "resonance",
            bridge_type: "growth_resonance_linking", timestamp_ms: 0,
        }) as bytes
        let (g2, bid_r) = graph_add_node(g, 0xB0, bridge_resonance)
        g = graph_add_edge(g2, id_growth, bid_r, EDGE_BRIDGE_TO, bridge_resonance)
    }

    // BRIDGE_TO: qmind_document_ingest -> PolyDocs parser
    if id_doc_ingest != 0xFFFFFFFF as u32 {
        let bridge_qdocs = serialize(PolymindBridgeEdgeData {
            source_lex: POLYMIND_APP_LEX, source_module: "qmind_document_ingest",
            target_lex: "polyqlabs/qdocs", target_module: "qdocs_parser",
            bridge_type: "document_parsing", timestamp_ms: 0,
        }) as bytes
        let (g2, bid2) = graph_add_node(g, 0xB0, bridge_qdocs)
        g = graph_add_edge(g2, id_doc_ingest, bid2, EDGE_BRIDGE_TO, bridge_qdocs)
    }

    g
}

// ═══════════════════════════════════════════════════════════════════════════════
// Internal helpers
// ═══════════════════════════════════════════════════════════════════════════════

circuit find_qmind_module_id(graph: CsrStorage, name: string) -> u32
    lex polyqlabs/qmind
    @status production
    @precision D
{
    for i in 0..graph.num_nodes {
        let node_data = graph.node_data[i]
        let module = deserialize(node_data) as ModuleNode
        if module.name == name {
            return i
        }
    }
    0xFFFFFFFF
}

// ── Metrics Store ──────────────────────────────────────────────────────────────

store series qmind_app_graph_metrics
    lex polyqlabs/qmind/metrics
{
    operation: string key
    module_count: u32
    edge_count: u32
    register_latency_ns: u64
    bridge_edge_count: u32
}

// ═══════════════════════════════════════════════════════════════════════════════
// §4  Golden Tests
// ═══════════════════════════════════════════════════════════════════════════════

#[test]
circuit test_qmind_app_graph_register()
    lex polyqlabs/qmind/test
{
    let empty = CsrStorage::new(4096)
    let g = qmind_app_graph_register(empty)
    assert g.num_nodes == 14, "expected 14 modules"
    assert g.num_edges >= 22, "expected at least 22 REQUIRES edges"
}

#[test]
circuit test_qmind_bridge_edges()
    lex polyqlabs/qmind/test
{
    let empty = CsrStorage::new(4096)
    let g = qmind_app_graph_register(empty)
    let g = qmind_register_bridge_edges(g)
    assert g.num_nodes == 17, "expected 14 modules + 3 bridge nodes"
}

#[test]
circuit test_find_qmind_module_id()
    lex polyqlabs/qmind/test
{
    let empty = CsrStorage::new(4096)
    let g = qmind_app_graph_register(empty)
    let id = find_qmind_module_id(g, "qmind_eslm")
    assert id != 0xFFFFFFFF, "qmind_eslm should be found"
    let missing = find_qmind_module_id(g, "nonexistent")
    assert missing == 0xFFFFFFFF, "nonexistent module should return sentinel"
}

#[test]
circuit test_make_qmind_module_defaults()
    lex polyqlabs/qmind/test
{
    let m = qmind_ingest_module()
    assert m.name == "qmind_ingest"
    assert m.version_major == 0
    assert m.version_minor == 1
    assert m.version_patch == 0
    assert m.sla_tier == SLATier::Premium as u8
    assert m.aperture_partition == AperturePartition::Backend as u8
}
