/// Spec: specs/POLYMIND_CE_APP_GRAPH_SPEC.md
/// PolyMind App Graph — 14 ModuleNode definitions composing the personal ESLM
/// corpus, digital legacy, and personal growth product. Registers intra-graph
/// REQUIRES edges and cross-graph BRIDGE_TO edges to QKit (ESLM classify),
/// PolyDocs (document ingest), and eStream Resonance (growth linking).

lex polyqlabs/qmind

@target software
@codegen_targets ["wasm", "rust", "wasm-browser"]

import "core/deployment/module_stratum.fl" {
    ModuleNode, ModuleEdge, SemVer, CompilationReceipt, ResourceBudget8D,
    CsrStorage, ModuleType, AperturePartition, ModuleState, RolloutState,
    PersistencePolicy, OfflineCachePolicy, EntitlementTier, EnforcementMode,
    SLATier, EDGE_REQUIRES, EDGE_BRIDGE_TO,
    module_graph_add_module, module_graph_add_edge,
    graph_add_node, graph_add_edge,
}

// ── Constants ──────────────────────────────────────────────────────────────────

const POLYMIND_VERSION_MAJOR: u32 = 0
const POLYMIND_VERSION_MINOR: u32 = 1
const POLYMIND_VERSION_PATCH: u32 = 0
const POLYMIND_APP_LEX: string = "polyqlabs/qmind"
const POLYMIND_VERSION_STR: string = "0.1.0"
const POLYMIND_MODULE_COUNT: u64 = 14

// ═══════════════════════════════════════════════════════════════════════════════
// Internal helper — common ModuleNode construction
// ═══════════════════════════════════════════════════════════════════════════════

circuit make_qmind_module(
    name: string, partition: u8, sla: u8, budget: ResourceBudget8D
) -> ModuleNode
    lex polyqlabs/qmind
    @status production
    @precision D
{
    let ver = SemVer { major: POLYMIND_VERSION_MAJOR, minor: POLYMIND_VERSION_MINOR,
        patch: POLYMIND_VERSION_PATCH, pre_release: "" }
    let receipt = CompilationReceipt {
        source_hash: bytes(32, 0), compiler_version: ver,
        output_hash: bytes(32, 0), prime_device_id: Option::None,
        compilation_timestamp: 0, reproducible_verified: false,
        receipt_signature: bytes(4627, 0),
    }

    ModuleNode {
        name: name,
        version_major: POLYMIND_VERSION_MAJOR, version_minor: POLYMIND_VERSION_MINOR,
        version_patch: POLYMIND_VERSION_PATCH, version_pre: "",
        module_type: ModuleType::SmartCircuit as u8,
        content_hash: bytes(32, 0), signature_chain: bytes(0),
        aperture_partition: partition,
        role_set: ["User", "Admin", "Guardian"],
        required_entitlement: EntitlementTier::Pro as u8,
        classification_domains: [], max_classification_level: 0,
        compilation_receipt: receipt,
        source_hash: bytes(32, 0),
        compiler_version_major: POLYMIND_VERSION_MAJOR,
        compiler_version_minor: POLYMIND_VERSION_MINOR,
        prime_device_id: bytes(0), reproducible_verified: false,
        resource_budget: budget,
        budget_enforcement_mode: EnforcementMode::Soft as u8,
        state: ModuleState::Active as u8,
        rollout_state: RolloutState::Canary as u8,
        canary_target: Option::None,
        persistence: PersistencePolicy::Persistent as u8,
        offline_cache_policy: OfflineCachePolicy::CacheAndVerify as u8,
        max_staleness_seconds: 3600, sla_tier: sla,
        preferred_locality: "edge",
        created_at_ms: 0, updated_at_ms: 0,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §1  Module Definitions — 13 ModuleNodes
// ═══════════════════════════════════════════════════════════════════════════════

// ── qmind_ingest ── content ingestion pipeline ────────────────────────────

circuit qmind_ingest_module() -> ModuleNode
    lex polyqlabs/qmind  @status production  @precision D
    observe metrics: [module_name]  meters [compute_cycles]
{
    make_qmind_module("qmind_ingest", AperturePartition::Backend as u8,
        SLATier::Premium as u8,
        ResourceBudget8D { execution: 50000, hash_ops: 2000, bandwidth: 20000,
            storage: 100000, observe_events: 500, proofs: 50, consensus: 10, memory: 33554432 })
}

